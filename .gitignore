# =============================================================================
# Open Design — .gitignore
# pnpm-workspace monorepo (apps/ packages/ tools/ e2e/), Electron + Next.js,
# packaged via tools-pack. Keep generated output, local runtime data, and
# secrets out of git.
# =============================================================================

# --- Dependencies ------------------------------------------------------------
node_modules/
.pnpm-store/

# --- Build output / generated ------------------------------------------------
dist/
out/
.next/
.next-*/
.vite/
.astro/
.wrangler/
*.tsbuildinfo
/OpenDesign.exe
# Nix build result symlinks
result
result-*

# --- Packaged build + local runtime data -------------------------------------
# tools-pack writes the packaged app, the win-unpacked tree, and the portable
# zip/installer under .tmp; the daemon and portable runs write their own data.
.tmp/

# Daemon runtime data — auto-created on first start. Holds app.sqlite (project
# metadata), projects/<id>/ (per-project artifacts / the agent's CWD),
# artifacts/ (one-off renders), and media-config.json (BYOK API CREDENTIALS).
# Never commit.
.od
.od-e2e
# Legacy folder name from before the rename; keep ignored so existing clones
# don't accidentally stage stale runtime data.
.ocd
# Portable-zip runtime data — lands beside the extracted exe, so this only
# appears in-tree if a portable build is launched from inside the repo.
OpenDesignData/

# --- Secrets / credentials  (matters most for a public repo) -----------------
.env
.env.*
!.env.example
!**/.env.example
# Belt-and-suspenders: the BYOK credentials file under any OD_MEDIA_CONFIG_DIR.
media-config.json
# Code-signing material, private keys, certificates.
*.pfx
*.p12
*.pem
*.key
*.crt
*.cer

# --- Test / coverage reports -------------------------------------------------
test-results
playwright-report
coverage/
.nyc_output/
*.lcov
e2e/.od-data
e2e/playwright-report
e2e/reports/html
e2e/reports/playwright-html-report
e2e/reports/test-results
e2e/reports/results.json
e2e/reports/junit.xml
e2e/reports/latest.md
e2e/ui/.od-data
e2e/ui/reports
e2e/ui/test-results
apps/web/playwright/
# Ad-hoc local e2e scripts and their screenshots
e2e/scripts/test-fal-webui.ts
e2e/scripts/fal-webui-*.png

# --- Logs --------------------------------------------------------------------
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Editors / IDEs ----------------------------------------------------------
.vscode
.idea/
*.swp
*.swo
*~

# --- OS cruft ----------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Agent / local tooling state ---------------------------------------------
.omo/
.playwright-mcp/
**/.claude-sessions/*
.cursor/
.agents/
.opencode/
.codex/
.deepseek/
.antigravitycli/
.ralph/
docs/superpowers/
# Commander task scratchpad; keep local task notes out of git by default.
.task/
task.md
specs/change/active

.claude/*
# Exception: od-contribute skill ships with the repo so the OD app can mount it
# for non-coder contributors. Personal Claude state (sessions, settings, etc.)
# stays ignored.
!.claude/skills/
.claude/skills/*
!.claude/skills/od-contribute/
!.claude/commands/
.claude/commands/*
!.claude/commands/od-contribute.md

# --- Nix / direnv ------------------------------------------------------------
.direnv/
.envrc

# --- Misc local --------------------------------------------------------------
.impeccable.md
# Landing-page preview thumbnails — regenerated by CI from skills/<slug>/
# example.html and templates/live-artifacts/<slug>/ on deploy (~70MB of PNGs).
apps/landing-page/public/previews/
growth/**

# --- Internal / fork-local docs (planning, analysis, agent session handoffs) --
# Not part of the product; kept out of the published fork. Anchored to root so
# same-named product files elsewhere are unaffected.
/findings.md
/refactor_ideas.md
/design-browser-task-handoff.md

# Local agent session archives (must stay out of git per AGENTS.md)
session_*.zip
